# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/whatsapp-platform
MONGO_DB_NAME=whatsapp-platform

# Meta WhatsApp Cloud API
# Em 2026-03-02, o changelog da Graph API indica v25.0 como versão mais recente.
META_API_URL=https://graph.facebook.com/v25.0
META_ACCESS_TOKEN=your_meta_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_VERIFY_TOKEN=your_webhook_verify_token_here
# Obrigatório em produção para validar assinatura x-hub-signature-256 do webhook.
# Em desenvolvimento pode ficar vazio.
META_APP_SECRET=your_app_secret_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
